{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "postinstall": "npm run build",
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production node server.js",
